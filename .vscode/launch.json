{
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Launch MariaDB - Test Vector - Create Table",
                "type": "gdb",
                "request": "launch",
		"program": "/app/build/sql/mariadbd",
		"args": ["--defaults-file=${env:HOME}/mariadb.cnf", "--user=root", "--init-file=/mnt/code/tmp/test-vector-create.sql", "--debug=d,info,error,query:o,/tmp/mariadb.trace"],
